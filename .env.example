# Copy this file to .env.local and fill in from your Supabase project settings
# (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bunny.net storage zone, for product image/video uploads
NEXT_PUBLIC_BUNNY_CDN_URL=https://your-zone.b-cdn.net
BUNNY_STORAGE_API_KEY=your-storage-api-key
